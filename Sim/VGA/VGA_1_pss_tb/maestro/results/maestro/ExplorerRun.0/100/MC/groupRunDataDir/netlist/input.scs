include "/opt/pdk/ams/410/spectre/c35/esddiode.scs" section=esddiodemc
include "netlist"
simulatorOptions options psfversion="1.4.0" temp=27 tnom=27 homotopy=all \
    limit=delta scalem=1.0 scale=1.0 compatible=spice2 gmin=1e-12 rforce=1 \
    maxnotes=5 maxwarns=5 digits=5 cols=80 pivrel=1e-3 \
    sensfile="../psf/sens.output" checklimitdest=psf enable_pre_ver=yes \
    ignorezerovar=yes 
mc1 montecarlo numruns=1 seed=12345 variations=all sampling=lds \
    donominal=no scalarfile="../monteCarlo/mcdata" \
    paramfile="../monteCarlo/mcparam" saveprocessparams=no \
    savemismatchparams=no savefamilyplots=yes savedatainseparatedir=yes \
    wfseparation=yes firstrun=100 {
tran tran stop=100m write="spectre.ic" writefinal="spectre.fc" \
    annotate=status 
